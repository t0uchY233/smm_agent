    {
      "parameters": {
        "jsCode": "// Webhook query доступен в $json.query (n8n nest under body/query/headers).\n// Возвращаем РОВНО ОДИН item — иначе Respond Lookup отправит первый и потеряет остальные.\n\nconst query = $('🔌 Webhook: Lookup (GET)').first().json.query || {};\nconst youtubeId = String(query.youtube_id || '').trim();\n\nif (!youtubeId) {\n  return [{ json: { found: false, row: null, error: 'youtube_id query param missing' } }];\n}\n\nconst rows = $input.all().map(i => i.json).filter(r => r && typeof r === 'object');\nconst match = rows.find(r => String(r.youtube_id || '').trim() === youtubeId);\n\nreturn [{ json: { found: !!match, row: match || null } }];"
      },
      "id": "lookup-find",
      "name": "🔍 Find by youtube_id",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1952,
        2000
      ]
    },
