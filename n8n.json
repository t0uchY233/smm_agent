    {
      "parameters": {
        "jsCode": "// Парсим имя видеофайла: формат YYYY-MM-DD-HHMM-alias.mp4\n// Пример: 2026-05-01-1400-burovye-krs.mp4\n//   → scheduledAt = 2026-05-01T11:00:00Z (UTC для YouTube publishAt)\n//   → scheduledAtMsk = \"2026-05-01 14:00\" (для Sheets)\n//   → videoTitle = \"burovye krs\" (alias с пробелами)\n//\n// Если имя не подпадает под формат — videoTitle = имя без расширения,\n// scheduledAt = null → видео уйдёт как public сразу.\n\nconst inputItems = $input.all();\nconst results = [];\n\nfor (const item of inputItems) {\n  const fileName = item.json.name || item.json.originalFilename || 'video';\n  const nameWithoutExt = fileName.replace(/\\.[^.]+$/, '');\n\n  let scheduledAt = null;\n  let scheduledAtMsk = null;\n  let title = nameWithoutExt;\n\n  const m = nameWithoutExt.match(/^(\\d{4})-(\\d{2})-(\\d{2})-(\\d{2})(\\d{2})-(.+)$/);\n  if (m) {\n    const [, yyyy, mm, dd, hh, mi, alias] = m;\n    const iso = `${yyyy}-${mm}-${dd}T${hh}:${mi}:00+03:00`;\n    const scheduled = new Date(iso);\n    const now = new Date();\n    const minFuture = new Date(now.getTime() + 15 * 60 * 1000);\n\n    if (!isNaN(scheduled.getTime()) && scheduled >= minFuture) {\n      scheduledAt = scheduled.toISOString();\n      scheduledAtMsk = `${yyyy}-${mm}-${dd} ${hh}:${mi}`;\n    }\n    title = alias.replace(/-/g, ' ');\n  }\n\n  const privacyStatus = scheduledAt ? 'private' : 'public';\n\n  results.push({\n    json: {\n      ...item.json,\n      videoTitle: title,\n      videoCategory: '22',\n      originalFileName: fileName,\n      scheduledAt,\n      scheduledAtMsk,\n      privacyStatus,\n      driveFileId: item.json.id\n    },\n    binary: item.binary\n  });\n}\n\nreturn results;"
      },
