    {
      "parameters": {
        "jsCode": "// Извлекаем base64 изображение из ответа OpenRouter\n// и пробрасываем дальше метаданные видео для последующих нод после Merge.\n\nconst imageUrl = $json.choices[0].message.images[0].image_url.url;\nconst base64Data = imageUrl.split(',')[1];\nconst mimeType = imageUrl.match(/data:([a-zA-Z0-9]+\\/[a-zA-Z0-9-.+]+).*,/)[1];\nconst extension = mimeType.includes('png') ? 'png' : 'jpg';\nconst fileName = `thumbnail_${Date.now()}.${extension}`;\n\nconst meta = $('📝 Парсинг имени').first().json;\n\nreturn {\n  json: {\n    fileName,\n    mimeType,\n    videoTitle: meta.videoTitle,\n    scheduledAt: meta.scheduledAt,\n    scheduledAtMsk: meta.scheduledAtMsk,\n    driveFileId: meta.driveFileId,\n    privacyStatus: meta.privacyStatus,\n    success: true\n  },\n  binary: {\n    thumbnail: {\n      data: base64Data,\n      mimeType,\n      fileName\n    }\n  }\n};"
      },
