    {
      "parameters": {
        "jsCode": "// Webhook payload приходит вложенным в $json.body — распаковываем\n// в плоский item, чтобы Google Sheets defineBelow корректно увидел поля.\n// Принимаем только разрешённые колонки (защита от мусора).\n\nconst ALLOWED = [\n  'youtube_id','youtube_url','drive_file_id','title','scheduled_at',\n  'tg_text','blog_html','blog_meta','blog_alias','blog_parent',\n  'cover_url','cover_local_path','status',\n  'published_at','tg_msg_id','blog_url','error'\n];\n\nconst results = [];\nfor (const item of $input.all()) {\n  const raw = (item.json && item.json.body) ? item.json.body : (item.json || {});\n  if (!raw.youtube_id) {\n    throw new Error('youtube_id отсутствует в теле запроса');\n  }\n\n  const cleaned = {};\n  for (const key of ALLOWED) {\n    if (raw[key] !== undefined && raw[key] !== null) {\n      cleaned[key] = raw[key];\n    }\n  }\n\n  results.push({ json: cleaned });\n}\nreturn results;"
      },
