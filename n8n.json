      "parameters": {
        "jsCode": "// Берём только строки готовые к публикации:\n//   status == 'ready' (нормализуем регистр + trim)\n//   scheduled_at <= now (MSK timezone +03:00)\n// Защищаемся от мусора в ячейках.\n\nconst now = Date.now();\nconst results = [];\n\nfor (const item of $input.all()) {\n  const row = item.json || {};\n  const status = String(row.status || '').trim().toLowerCase();\n  if (status !== 'ready') continue;\n\n  const sched = String(row.scheduled_at || '').trim();\n  if (!sched) continue;\n\n  // \"YYYY-MM-DD HH:MM\" → ISO в MSK\n  const iso = sched.replace(' ', 'T') + ':00+03:00';\n  const ts = new Date(iso).getTime();\n  if (isNaN(ts)) continue;\n  if (ts > now) continue;\n\n  results.push({ json: row });\n}\n\nreturn results;"
      },
