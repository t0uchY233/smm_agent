      "parameters": {
        "jsCode": "// Фильтруем по youtube_id из query-параметра webhook.\n// Всегда возвращаем ровно один item, чтобы Respond Lookup сработал даже на пустом результате.\nconst query = $('🔌 Webhook: Lookup').item.json.query || {};\nconst youtubeId = String(query.youtube_id || '').trim();\n\nif (!youtubeId) {\n  return [{ json: { found: false, row: null, error: 'youtube_id query param missing' } }];\n}\n\nconst rows = $input.all().map(i => i.json).filter(r => r && typeof r === 'object');\nconst match = rows.find(r => String(r.youtube_id || '').trim() === youtubeId);\n\nreturn [{ json: { found: !!match, row: match || null } }];"
      },
