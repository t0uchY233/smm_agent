      "parameters": {
        "jsCode": "// Находим строки: загружено, контент не готов, 1-3 часа до публикации, напоминание ещё не отправлено\nconst now = Date.now();\nconst in1h = now + 60 * 60 * 1000;\nconst in3h = now + 3 * 60 * 60 * 1000;\nconst results = [];\n\nfor (const item of $input.all()) {\n  const row = item.json;\n  if (row.status !== 'uploaded') continue;\n  if (!row.scheduled_at) continue;\n  // Идемпотентность: если напоминание уже отправлено — пропускаем\n  if (row.reminded_at && String(row.reminded_at).trim() !== '') continue;\n\n  const iso = String(row.scheduled_at).trim().replace(' ', 'T') + ':00+03:00';\n  const scheduled = new Date(iso).getTime();\n  if (isNaN(scheduled)) continue;\n  if (scheduled < in1h || scheduled > in3h) continue;\n\n  results.push({ json: row });\n}\n\nreturn results;"
      },
      "id": "filter-reminder",
      "name": "🔍 Filter: uploaded & 1-3h away",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
