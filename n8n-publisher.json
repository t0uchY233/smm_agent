      "parameters": {
        "jsCode": "// Webhook body приходит вложенным в $json.body.\n// Распаковываем в плоский item, чтобы Google Sheets autoMapInputData\n// корректно смапил поля (youtube_id, tg_text, status и т.д.) в колонки.\nconst results = [];\nfor (const item of $input.all()) {\n  const body = item.json && item.json.body ? item.json.body : item.json || {};\n  if (!body.youtube_id) {\n    throw new Error('youtube_id отсутствует в теле запроса');\n  }\n  results.push({ json: body });\n}\nreturn results;"
