      "parameters": {
        "jsCode": "// Оставляем строки готовые к публикации: status=ready и scheduled_at <= now() в MSK\nconst now = Date.now();\nconst results = [];\n\nfor (const item of $input.all()) {\n  const row = item.json;\n  if (row.status !== 'ready') continue;\n  if (!row.scheduled_at) continue;\n\n  // scheduled_at формат: \"2026-05-01 14:00\" (MSK)\n  const iso = String(row.scheduled_at).trim().replace(' ', 'T') + ':00+03:00';\n  const scheduled = new Date(iso).getTime();\n  if (isNaN(scheduled)) continue;\n  if (scheduled > now) continue;\n\n  results.push({ json: row });\n}\n\nreturn results;"
      },
