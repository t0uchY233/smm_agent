# Скопируй этот файл в .env и заполни своими значениями.
# .env находится в .gitignore — никогда не коммить реальные ключи.

# Blotato API (https://help.blotato.com/api/llm) — опционально, для доп. визуалов
BLOTATO_API_KEY=your_blotato_api_key_here

# OpenRouter API (https://openrouter.ai) — для генерации обложек через Gemini
OPENROUTER_API_KEY=sk-or-v1-...

# AssemblyAI Speech-to-Text — для синхронизации карточек с речью в /render-with-visuals
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
ASSEMBLYAI_LANGUAGE_CODE=ru

# Telegram Bot API (https://core.telegram.org/bots/api)
# Создать бота: @BotFather → /newbot. Бот должен быть админом канала -1001972632255
TELEGRAM_BOT_TOKEN=000000000:AAA-XXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# n8n Publisher webhooks (no auth)
# Эти URL уже зашиты в n8n.json — менять только если поднимаете свой n8n
N8N_BASE_URL=https://bigetn8n.casacam.net
N8N_WEBHOOK_UPDATE=https://bigetn8n.casacam.net/webhook/905e8882-caab-4e40-8f42-c6f63524f3e8
N8N_WEBHOOK_LOOKUP=https://bigetn8n.casacam.net/webhook/e5bdfd41-4fad-4442-b707-1d416bd5c3b2

# Google Sheets — очередь отложенных публикаций (лист "schedule")
SMM_SCHEDULE_SPREADSHEET_ID=13CleoQqkhSuWg65fX1bH20ScOgYhqzEx4yg20bNU3ZY

# WordPress REST API — для медиа и публикаций блога
WORDPRESS_BASE_URL="https://example.com"
WORDPRESS_API_BASE_URL="https://example.com/wp-json/wp/v2"
WORDPRESS_USERNAME="automation_bot"
WORDPRESS_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

WORDPRESS_DEFAULT_POST_STATUS="draft"
WORDPRESS_DEFAULT_CATEGORY_IDS=""
WORDPRESS_DEFAULT_TAG_IDS=""
WORDPRESS_TIMEOUT_SECONDS="30"
